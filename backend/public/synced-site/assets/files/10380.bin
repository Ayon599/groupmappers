/\/groupmappers.com\/wp-content\/uploads\/2023\/06\/sinha.jpg\" class=\"attachment-large size-large wp-image-12396\" alt=\"\" srcset=\"https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/06\/sinha.jpg 357w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/06\/sinha-298x300.jpg 298w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/06\/sinha-150x150.jpg 150w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/06\/sinha-50x50.jpg 50w\" sizes=\"(max-width: 357px) 100vw, 357px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-4202df8 elementor-widget elementor-widget-text-editor\" data-id=\"4202df8\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Ipsita Sinha<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-0b299ae elementor-widget elementor-widget-text-editor\" data-id=\"0b299ae\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Research Physician<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-64307d6 elementor-widget elementor-widget-text-editor\" data-id=\"64307d6\" data-element_type=\"widget\" data-e-type=\"widget\" id=\"latest-news\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p style=\"text-align: center;\">Dr Ipsita Sinha is part of the Epidemiology department at MORU, and a Research Physician in Tropical Medicine at the University of Oxford. She is also an honorary medical registrar at the John Radcliffe Hospital in Oxford.<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-d51179b elementor-widget elementor