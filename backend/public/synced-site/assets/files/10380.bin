p-column elementor-element elementor-element-3c6ac47\" data-id=\"3c6ac47\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-98e42bc elementor-widget__width-initial elementor-widget elementor-widget-image\" data-id=\"98e42bc\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img loading=\"lazy\" decoding=\"async\" width=\"879\" height=\"1024\" src=\"https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-879x1024.jpg\" class=\"attachment-large size-large wp-image-11516\" alt=\"\" srcset=\"https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-879x1024.jpg 879w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-258x300.jpg 258w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-768x894.jpg 768w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-1319x1536.jpg 1319w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-scaled.jpg 1759w, https:\/\/groupmappers.com\/wp-content\/uploads\/2023\/03\/Sazid-Ibna-Zaman-900x1048.jpg 900w\" sizes=\"(max-width: 879px) 100vw, 879px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-2f571cf elementor-widget elementor-widget-text-editor\" data-id=\"2f571cf\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Sazid Ibna Zaman<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-46f8ff5 elementor-widget elementor-widget-text-editor\" data-id=\"46f8ff5\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Data Manager &amp; GIS Specialist<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-116f1c7 elementor-widget elementor-widget-text-editor\" data-id=\"116f1c7\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p style=\"text-align: center;\">Based in Dhaka, Bangladesh, Sazid Ibna Zaman is a Data Manager &amp; GIS Specialist for the MORU Epidemiology departments at the Mahidol Oxford Tropical Medicine Research Unit (MORU), Bangkok, Thailand<\/p>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-89a1159 elementor-widget elementor-widget-spacer\" data-id=\"89a1159\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"spacer.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t<div class=\"elementor-spacer\">\n\t\t\t<div class=\"elementor-spacer-inner\"><\/div>\n\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-8bcf708 elementor-shape-circle elementor-widget__width-initial elementor-grid-0 e-grid-align-center elementor-widget elementor-widget-social-icons\" data-id=\"8bcf708\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"social-icons.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t<div class=\"elementor-social-icons-wrapper elementor-grid\" role=\"list\">\n\t\t\t\t\t\t\t<span class=\"elementor-grid-item\" role=\"listitem\">\n\t\t\t\t\t<a class=\"elementor-icon elementor-social-icon elementor-social-icon- elementor-repeater-item-c8feaf1\" href=\"https:\/\/www.tropmedres.ac\/team\/sazid-ibna-zaman\" target=\"_blank\">\n\t\t\t\t\t\t<span class=\"elementor-screen-only\"><\/span>\n\t\t\t\t\t\